{
  "name": "memo-app",
  "version": "1.0.0",
  "description": "A beautiful memo application built with Cloudflare Pages and D1",
  "main": "index.js",
  "scripts": {
    "dev": "wrangler pages dev public --compatibility-date=2024-01-01",
    "deploy": "wrangler pages deploy public",
    "db:migrate": "wrangler d1 migrations apply memo-db",
    "db:create": "wrangler d1 create memo-db",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report"
  },
  "keywords": [
    "memo",
    "notes",
    "cloudflare",
    "d1",
    "pages"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "wrangler": "^4.25.1"
  }
}
