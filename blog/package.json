{
	"name": "blog",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"db:init": "node scripts/init-db.js",
		"db:migrate": "wrangler d1 execute blog-db --local --file=database/schema.sql",
		"db:seed": "wrangler d1 execute blog-db --local --file=database/seed.sql",
		"db:reset": "npm run db:migrate && npm run db:seed"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.8.19",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.26.0"
	}
}
