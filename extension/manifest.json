{
  "manifest_version": 3,
  "name": "Memo - 快速记录",
  "version": "1.0.0",
  "description": "一键保存网页内容到 Memo，支持快捷键、右键菜单和侧边栏",
  "author": "Memo App",
  "homepage_url": "https://main.memo-app-1xs.pages.dev",
  
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "alarms",
    "clipboardRead"
  ],
  
  "host_permissions": [
    "https://main.memo-app-1xs.pages.dev/*",
    "https://*.memo-app-1xs.pages.dev/*"
  ],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Memo - 快速记录"
  },
  
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "打开快速记录窗口"
    },
    "save-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "保存选中文字"
    }
  },
  
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}